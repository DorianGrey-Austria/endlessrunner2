{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/doriangrey/Desktop/coding/EndlessRunner",
        "/Users/doriangrey/Desktop",
        "/Users/doriangrey/Documents"
      ]
    },
    
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_DEIN_TOKEN_HIER"
      }
    },
    
    "git": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-git",
        "--repository",
        "/Users/doriangrey/Desktop/coding/EndlessRunner"
      ]
    },
    
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "DEIN_BRAVE_API_KEY_HIER"
      }
    },
    
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ]
    },
    
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-playwright",
        "--project",
        "/Users/doriangrey/Desktop/coding/EndlessRunner/SubwayRunner"
      ]
    },
    
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    
    "imagemagick": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "--name", "mcp-imagemagick",
        "--mount", "type=bind,src=/Users/doriangrey/Desktop/coding/EndlessRunner/SubwayRunner/assets,dst=/workspace",
        "--memory", "256m",
        "--cpus", "0.5",
        "--security-opt", "no-new-privileges",
        "dpokidov/imagemagick:latest"
      ]
    },
    
    "godot": {
      "command": "npx",
      "args": [
        "-y",
        "godot-mcp",
        "--project-path",
        "/Users/doriangrey/Desktop/coding/EndlessRunner/godot-mcp"
      ]
    },
    
    "sqlite": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sqlite",
        "--db-path",
        "/Users/doriangrey/Desktop/coding/EndlessRunner/game_stats.db"
      ]
    }
  }
}