{"type":"frame-snapshot","snapshot":{"callId":"call@9","snapshotName":"after@call@9","pageId":"page@608583aab1e06c3ad31232762615eeb7","frameId":"frame@6de9b923264fec3719a3869d30c5d0f6","frameUrl":"http://localhost:8001/index.html","doctype":"html","html":["HTML",{"lang":"de"},["HEAD",{},["BASE",{"href":"http://localhost:8001/index.html"}],"\n    ",["META",{"charset":"utf-8"}],"\n    ",["META",{"name":"viewport","content":"width=device-width, initial-scale=1.0"}],"\n    ",["TITLE",{},"Subway Runner 3D - V4.3-STABLE-MULTIJUMP"],"\n    ","\n    ","\n    ","\n    ","\n    ",["STYLE",{},"\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n        \n        body {\n            background: linear-gradient(to bottom, #87CEEB 0%, #98FB98 100%);\n            font-family: Arial, sans-serif;\n            overflow: hidden;\n        }\n\n        \n        #gameContainer {\n            width: 100vw;\n            height: 100vh;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n        }\n        \n        #gameCanvas {\n            width: 100%;\n            height: 100%;\n            max-width: 133.33vh; /* 4:3 aspect ratio */\n            max-height: 75vw;\n            border: 2px solid #333;\n            border-radius: 8px;\n        }\n        \n        #ui {\n            position: absolute;\n            top: 20px;\n            left: 20px;\n            color: white;\n            font-size: 24px;\n            font-weight: bold;\n            text-shadow: 2px 2px 4px rgba(0,0,0,0.8);\n            z-index: 100;\n            display: none;\n        }\n\n        #instructions {\n            position: absolute;\n            bottom: 20px;\n            right: 20px;\n            color: white;\n            font-size: 14px;\n            text-shadow: 1px 1px 2px rgba(0,0,0,0.8);\n            text-align: right;\n            z-index: 100;\n            display: none;\n        }\n        \n        #menu {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            background: rgba(10, 10, 20, 0.92);\n            backdrop-filter: blur(12px);\n            -webkit-backdrop-filter: blur(12px);\n            color: white;\n            padding: 36px 32px 28px;\n            border-radius: 20px;\n            text-align: center;\n            z-index: 200;\n            min-width: 340px;\n            max-width: 420px;\n            border: 1px solid rgba(255,255,255,0.08);\n            box-shadow: 0 20px 60px rgba(0,0,0,0.6);\n        }\n\n        #menu h1 {\n            margin: 0 0 4px;\n            font-size: 28px;\n            letter-spacing: -0.5px;\n        }\n\n        #menu .menu-subtitle {\n            color: #f0c040;\n            font-size: 14px;\n            font-weight: 600;\n            margin: 0 0 16px;\n            letter-spacing: 1px;\n            text-transform: uppercase;\n        }\n\n        #menu .menu-info {\n            font-size: 13px;\n            color: #aab;\n            margin: 0 0 6px;\n            line-height: 1.5;\n        }\n\n        #menu .menu-section {\n            margin-top: 16px;\n            padding-top: 14px;\n            border-top: 1px solid rgba(255,255,255,0.08);\n        }\n\n        #menu .menu-section-label {\n            font-size: 11px;\n            text-transform: uppercase;\n            letter-spacing: 1.5px;\n            color: #667;\n            margin: 0 0 10px;\n        }\n\n        #menu .start-btn {\n            display: block;\n            width: 100%;\n            font-size: 20px;\n            padding: 14px 0;\n            background: linear-gradient(135deg, #4CAF50, #2e7d32);\n            color: white;\n            border: none;\n            border-radius: 12px;\n            cursor: pointer;\n            font-weight: 700;\n            letter-spacing: 0.5px;\n            transition: transform 0.15s, box-shadow 0.15s;\n            box-shadow: 0 4px 16px rgba(76, 175, 80, 0.3);\n        }\n\n        #menu .start-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 24px rgba(76, 175, 80, 0.45);\n        }\n\n        #menu .start-btn:active {\n            transform: translateY(0);\n        }\n\n        #menu .gesture-btns {\n            display: flex;\n            gap: 10px;\n            justify-content: center;\n        }\n\n        #menu .gesture-btn {\n            flex: 1;\n            padding: 10px 8px;\n            border: 1px solid rgba(255,255,255,0.12);\n            border-radius: 10px;\n            background: rgba(255,255,255,0.04);\n            color: white;\n            cursor: pointer;\n            font-size: 13px;\n            transition: background 0.15s, border-color 0.15s, transform 0.15s;\n        }\n\n        #menu .gesture-btn:hover {\n            background: rgba(255,255,255,0.1);\n            border-color: rgba(255,255,255,0.25);\n            transform: translateY(-1px);\n        }\n\n        #menu .gesture-btn .gesture-icon {\n            font-size: 24px;\n            display: block;\n            margin-bottom: 4px;\n        }\n\n        #menu .gesture-btn .gesture-label {\n            font-weight: 600;\n            font-size: 13px;\n        }\n\n        #menu .gesture-btn .gesture-desc {\n            font-size: 10px;\n            color: #889;\n            margin-top: 2px;\n        }\n\n        #menu .settings-row {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 16px;\n            margin-top: 12px;\n        }\n\n        #menu .toggle-btn {\n            background: none;\n            border: 1px solid rgba(255,255,255,0.15);\n            border-radius: 8px;\n            color: #aab;\n            padding: 6px 14px;\n            font-size: 13px;\n            cursor: pointer;\n            transition: all 0.15s;\n            display: flex;\n            align-items: center;\n            gap: 6px;\n        }\n\n        #menu .toggle-btn:hover {\n            border-color: rgba(255,255,255,0.3);\n            color: white;\n        }\n\n        #menu .toggle-btn.active {\n            border-color: #4CAF50;\n            color: #4CAF50;\n        }\n\n        #menu .controls-hint {\n            font-size: 11px;\n            color: #556;\n            margin: 12px 0 0;\n        }\n\n        #menu .quality-toggle {\n            display: flex;\n            gap: 8px;\n            margin-top: 10px;\n        }\n\n        #menu .quality-btn {\n            flex: 1;\n            padding: 8px 6px;\n            border: 1px solid rgba(255,255,255,0.12);\n            border-radius: 10px;\n            background: rgba(255,255,255,0.04);\n            color: #889;\n            cursor: pointer;\n            font-size: 12px;\n            transition: all 0.2s;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 2px;\n        }\n\n        #menu .quality-btn:hover {\n            background: rgba(255,255,255,0.08);\n            border-color: rgba(255,255,255,0.25);\n        }\n\n        #menu .quality-btn.active {\n            border-color: #7c4dff;\n            background: rgba(124, 77, 255, 0.15);\n            color: #c9b3ff;\n        }\n\n        #menu .quality-btn .quality-icon {\n            font-size: 18px;\n        }\n\n        #menu .quality-btn .quality-label {\n            font-size: 11px;\n            font-weight: 600;\n        }\n\n        #timer {\n            font-size: 20px;\n            margin-top: 5px;\n        }\n        \n        #gestureControl {\n            position: fixed !important;\n            top: 20px !important;\n            right: 20px !important;\n            z-index: 9999 !important;\n            display: none;\n        }\n        \n        #gestureControlBtn {\n            background: rgba(0, 255, 136, 0.9);\n            color: #000;\n            border: none;\n            padding: 10px 20px;\n            font-size: 16px;\n            font-weight: bold;\n            border-radius: 8px;\n            cursor: pointer;\n            box-shadow: 0 2px 10px rgba(0, 255, 136, 0.3);\n            transition: all 0.3s;\n        }\n        \n        #gestureControlBtn:hover {\n            background: #00ff88;\n            transform: translateY(-2px);\n            box-shadow: 0 4px 15px rgba(0, 255, 136, 0.5);\n        }\n        \n        #gestureControlBtn.active {\n            background: #ff4444;\n        }\n        \n        #gestureCanvas {\n            position: absolute;\n            bottom: 20px;\n            left: 20px;\n            width: 180px;\n            height: 135px;\n            border: 2px solid #00ff88;\n            border-radius: 8px;\n            display: none;\n            z-index: 150;\n            background: #000;\n        }\n        \n        #gestureCanvas.active {\n            display: block;\n        }\n        \n        #gestureStatus {\n            position: absolute;\n            top: 60px;\n            right: 20px;\n            background: rgba(0, 0, 0, 0.8);\n            color: #00ff88;\n            padding: 10px;\n            border-radius: 8px;\n            font-size: 14px;\n            display: none;\n            z-index: 150;\n        }\n        \n        #gestureStatus.active {\n            display: block;\n        }\n\n        /* Gesture Mode Selector */\n        #gestureModeSelector {\n            display: none;\n            margin-top: 10px;\n            background: rgba(0, 0, 0, 0.8);\n            padding: 10px;\n            border-radius: 8px;\n            gap: 8px;\n        }\n\n        #gestureModeSelector.active {\n            display: flex;\n            flex-direction: column;\n        }\n\n        #gestureModeSelect {\n            padding: 8px;\n            border-radius: 6px;\n            border: 1px solid #00ff88;\n            background: #1a1a2e;\n            color: #fff;\n            font-size: 14px;\n            cursor: pointer;\n        }\n\n        #gestureModeSelect:focus {\n            outline: none;\n            border-color: #58a6ff;\n        }\n\n        #recalibrateBtn {\n            padding: 8px 12px;\n            background: #58a6ff;\n            color: white;\n            border: none;\n            border-radius: 6px;\n            cursor: pointer;\n            font-size: 14px;\n            font-weight: bold;\n        }\n\n        #recalibrateBtn:hover {\n            background: #4a90e2;\n        }\n\n        #calibrationProgress {\n            display: none;\n            margin-top: 8px;\n            background: #30363d;\n            border-radius: 4px;\n            height: 8px;\n            overflow: hidden;\n        }\n\n        #calibrationProgress.active {\n            display: block;\n        }\n\n        #calibrationProgressFill {\n            height: 100%;\n            background: linear-gradient(90deg, #238636, #3fb950);\n            width: 0%;\n            transition: width 0.3s;\n        }\n        \n        .timer-warning {\n            color: #FF4444 !important;\n            animation: pulse 0.5s infinite;\n        }\n        \n        .timer-critical {\n            color: #FF0000 !important;\n            animation: fastPulse 0.2s infinite;\n            font-weight: bold;\n        }\n        \n        @keyframes pulse {\n            0%, 100% { opacity: 1; }\n            50% { opacity: 0.7; }\n        }\n        \n        @keyframes fastPulse {\n            0%, 100% { opacity: 1; transform: scale(1); }\n            50% { opacity: 0.8; transform: scale(1.1); }\n        }\n        \n        .name-input-dialog {\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            background: rgba(0,0,0,0.9);\n            color: white;\n            padding: 30px;\n            border-radius: 16px;\n            z-index: 300;\n            text-align: center;\n            min-width: 350px;\n            border: 2px solid #4CAF50;\n        }\n        \n        .name-input-dialog input {\n            width: 200px;\n            padding: 10px;\n            margin: 15px;\n            border: none;\n            border-radius: 8px;\n            font-size: 16px;\n            text-align: center;\n        }\n        \n        .name-input-dialog button {\n            background: #4CAF50;\n            color: white;\n            border: none;\n            padding: 10px 20px;\n            margin: 5px;\n            border-radius: 8px;\n            cursor: pointer;\n            font-size: 14px;\n        }\n        \n        .name-input-dialog button:hover {\n            background: #45a049;\n        }\n        \n        .name-input-dialog button:disabled {\n            background: #666;\n            cursor: not-allowed;\n        }\n        \n        .highscore-panel {\n            position: absolute;\n            top: 20px;\n            right: 20px;\n            background: rgba(0,0,0,0.7);\n            color: white;\n            padding: 15px;\n            border-radius: 8px;\n            z-index: 100;\n            min-width: 200px;\n            font-size: 12px;\n        }\n        \n        .highscore-entry {\n            margin: 2px 0;\n            padding: 2px 0;\n        }\n        \n        .highscore-entry.current-player {\n            color: #4CAF50;\n            font-weight: bold;\n        }\n    "],"\n"],"\n",["BODY",{},"\n    ",["DIV",{"id":"gameContainer"},"\n        ",["CANVAS",{"__playwright_bounding_rect__":"{\"left\":160.015625,\"top\":0,\"right\":1119.984375,\"bottom\":720}","id":"gameCanvas","data-engine":"three.js r158"}],"\n        \n        ",["DIV",{"id":"ui"},"\n            ",["DIV",{},"Score: ",["SPAN",{"id":"score"},"0"]],"\n            ",["DIV",{},"Speed: ",["SPAN",{"id":"speed"},"100"]],"\n            ",["DIV",{},"❤️ Leben: ",["SPAN",{"id":"lives"},"3"]],"\n            ",["DIV",{"id":"timer"},"⏱️ Zeit: ",["SPAN",{