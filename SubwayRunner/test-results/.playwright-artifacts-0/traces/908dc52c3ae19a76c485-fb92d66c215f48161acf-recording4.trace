;\n            width: 180px;\n            height: 135px;\n            border: 2px solid #00ff88;\n            border-radius: 8px;\n            display: none;\n            z-index: 150;\n            background: #000;\n        }\n        \n        #gestureCanvas.active {\n            display: block;\n        }\n        \n        #gestureStatus {\n            position: absolute;\n            top: 60px;\n            right: 20px;\n            background: rgba(0, 0, 0, 0.8);\n            color: #00ff88;\n            padding: 10px;\n            border-radius: 8px;\n            font-size: 14px;\n            display: none;\n            z-index: 150;\n        }\n        \n        #gestureStatus.active {\n            display: block;\n        }\n\n        /* Gesture Mode Selector */\n        #gestureModeSelector {\n            display: none;\n            margin-top: 10px;\n            background: rgba(0, 0, 0, 0.8);\n            padding: 10px;\n            border-radius: 8px;\n            gap: 8px;\n        }\n\n        #gestureModeSelector.active {\n            display: flex;\n            flex-direction: column;\n        }\n\n        #gestureModeSelect {\n            padding: 8px;\n            border-radius: 6px;\n            border: 1px solid #00ff88;\n            background: #1a1a2e;\n            color: #fff;\n            font-size: 14px;\n            cursor: pointer;\n        }\n\n        #gestureModeSelect:focus {\n            outline: none;\n            border-color: #58a6ff;\n        }\n\n        #recalibrateBtn {\n            padding: 8px 12px;\n            background: #58a6ff;\n            color: white;\n            border: none;\n            border-radius: 6px;\n            cursor: pointer;\n            font-size: 14px;\n            font-weight: bold;\n        }\n\n        #recalibrateBtn:hover {\n            background: #4a90e2;\n        }\n\n        #calibrationProgress {\n            display: none;\n            margin-top: 8px;\n            background: #30363d;\n  