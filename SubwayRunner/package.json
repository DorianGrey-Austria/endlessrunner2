{
  "name": "subway-runner",
  "private": true,
  "version": "6.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "node test-runner.js",
    "test:watch": "nodemon test-runner.js",
    "serve": "live-server --port=8001 --watch=. --ignore=node_modules",
    "pretest": "echo '🧪 Running pre-deployment tests...'",
    "predeploy": "npm run test && echo '✅ Tests passed - ready for deployment'",

    "test:playwright": "npx playwright test",
    "test:smoke": "npx playwright test tests/e2e/core-gameplay/basic-gameplay.spec.js --project=Desktop-Chrome",
    "test:cache": "npx playwright test tests/integration/cache-busting.spec.js",
    "test:performance": "npx playwright test tests/performance/fps-monitoring.spec.js",
    "test:mobile": "npx playwright test --project=Mobile-iPhone12",
    "test:auto": "node tests/utils/auto-test-generator.js && npx playwright test tests/generated/",
    "test:all": "npm run test && npm run test:playwright",
    "test:live": "npx playwright test --config=playwright.config.js",
    "test:debug": "npx playwright test --debug",
    "test:headed": "npx playwright test --headed",

    "report:open": "npx playwright show-report tests/reports/html-report",
    "report:dashboard": "open tests/reports/game-dashboard.html || xdg-open tests/reports/game-dashboard.html",
    "generate:tests": "node tests/utils/auto-test-generator.js",

    "self-test": "npx playwright test tests/e2e/simple-validation.spec.js --project=Desktop-Chrome --reporter=list && echo '✅ Self-test completed successfully'",
    "validate": "npm run generate:tests && npm run self-test"
  },
  "dependencies": {
    "@react-three/drei": "^9.88.13",
    "@react-three/fiber": "^8.15.11",
    "@types/three": "^0.158.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.158.0",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.1.1",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "live-server": "^1.2.2",
    "nodemon": "^3.0.0",
    "@playwright/test": "^1.40.0"
  }
}